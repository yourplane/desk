; desk config
; Copy to ~/.config/desk/config.ini (or set DESK_CONFIG to your path).
; Subcommand flags --region / --profile still override; so do AWS_REGION / AWS_PROFILE.
;
; Desk profile: set DESK_PROFILE, or pass the global --profile before the subcommand
; (e.g. desk --profile work list), or set desk_profile in [default] below.
; Named sections [profile NAME] hold per-profile defaults. Legacy [defaults] is still read.
; State (routes, logs) is under ~/.local/state/desk/<NAME>/ when a desk profile is active.

[default]
desk_profile = personal
region = us-east-1
aws_profile = fallback-aws-profile
; ami_prefix = my-desk-ami

[profile personal]
region = us-east-1
aws_profile = my-personal-aws
ami_prefix = desk-ami-personal

[profile work]
region = eu-west-1
aws_profile = work-aws
ami_prefix = desk-ami-work
