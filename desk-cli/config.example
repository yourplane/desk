; desk config
; Copy to ~/.config/desk/config.ini (or set DESK_CONFIG to your path).
; AWS region and credential profile: AWS_REGION, AWS_PROFILE, or region / aws_profile
; in [default] or in [profile NAME] when that profile is active.
;
; [default] is your default desk profile. Optional [profile NAME] blocks are alternates.
; To switch: set DESK_PROFILE, optional desk_profile= in [default], or:
;   desk --profile work list
; State (routes, logs) is under ~/.local/state/desk/<NAME>/ when a named profile is active.

[default]
region = us-east-1
aws_profile = fallback-aws-profile
; desk_profile = personal   ; optional: use [profile personal] for AWS defaults
; ami_prefix = my-desk-ami

[profile personal]
region = us-east-1
aws_profile = my-personal-aws
ami_prefix = desk-ami-personal

[profile work]
region = eu-west-1
aws_profile = work-aws
ami_prefix = desk-ami-work
