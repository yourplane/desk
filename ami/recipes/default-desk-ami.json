{
  "ami_name": "default-desk-ami",
  "copy": [
    {
      "source": "../aws/install-aws-cli.sh",
      "dest": "/home/ubuntu/install-aws-cli.sh"
    },
    {
      "source": "../git",
      "dest": "/home/ubuntu/desk-git",
      "recursive": true
    },
    {
      "source": "../desk/update-desk",
      "dest": "/home/ubuntu/update-desk"
    },
    {
      "source": "../desk/config.ini",
      "dest": "/home/ubuntu/desk-config.ini"
    },
    {
      "source": "../cursor/install-cursor-agent.sh",
      "dest": "/home/ubuntu/install-cursor-agent.sh"
    }
  ],
  "run": [
    "sudo bash /home/ubuntu/install-aws-cli.sh",
    "sudo -u ubuntu HOME=/home/ubuntu bash /home/ubuntu/desk-git/install-git-credential-refresh-service.sh",
    "sudo apt-get update -qq && sudo apt-get install -y python3-venv",
    "sudo -u ubuntu bash -c 'python3 -m venv /home/ubuntu/tox-venv && /home/ubuntu/tox-venv/bin/pip install tox'",
    "sudo -u ubuntu git clone https://github.com/maxrademacher/desk.git /home/ubuntu/desk",
    "sudo -u ubuntu bash -c 'export PATH=\"/home/ubuntu/tox-venv/bin:$PATH\"; bash /home/ubuntu/update-desk'",
    "sudo -u ubuntu mv /home/ubuntu/update-desk /home/ubuntu/desk/update-desk && sudo -u ubuntu chmod +x /home/ubuntu/desk/update-desk",
    "sudo -u ubuntu bash -c 'echo \"export PATH=\\\"/home/ubuntu/desk/.tox/py/bin:/home/ubuntu/desk:/home/ubuntu/tox-venv/bin:\\$PATH\\\"\" >> /home/ubuntu/.bashrc'",
    "sudo -u ubuntu bash -c 'grep -q desk/.tox/py/bin /home/ubuntu/.profile 2>/dev/null || echo \"export PATH=\\\"/home/ubuntu/desk/.tox/py/bin:/home/ubuntu/desk:/home/ubuntu/tox-venv/bin:\\$PATH\\\"\" >> /home/ubuntu/.profile'",
    "sudo -u ubuntu bash -c 'mkdir -p /home/ubuntu/.config/desk && cp /home/ubuntu/desk-config.ini /home/ubuntu/.config/desk/config.ini'",
    "sudo bash /home/ubuntu/install-cursor-agent.sh"
  ]
}