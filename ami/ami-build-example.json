{
  "workstation_name": "ami-builder",
  "instance_type": "t3.medium",
  "key": "main-key",
  "copy": [
    { "source": "./scripts", "dest": "/home/ubuntu/scripts", "recursive": true },
    { "source": "./files/config.json", "dest": "/home/ubuntu/config.json" }
  ],
  "run": [
    "bash /home/ubuntu/scripts/setup.sh",
    "sudo /home/ubuntu/scripts/install-packages.sh"
  ],
  "ami_name": "my-custom-ami"
}
